# IndexPulse Configuration
# Copy to .env and adjust as needed

# Default index dimension (optional, can be set in code)
INDEXPULSE_DIMENSION=128

# Default distance metric: cosine | euclidean | dot_product
INDEXPULSE_DEFAULT_METRIC=cosine

# Maximum number of vectors (0 = unlimited)
INDEXPULSE_MAX_VECTORS=0

# Auto-normalize vectors on add (true/false)
INDEXPULSE_NORMALIZE_ON_ADD=false

# Log level: DEBUG | INFO | WARNING | ERROR
INDEXPULSE_LOG_LEVEL=INFO
